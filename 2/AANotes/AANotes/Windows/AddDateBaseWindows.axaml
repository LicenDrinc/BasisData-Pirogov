<Window xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d" d:DesignWidth="0" d:DesignHeight="0" Width="400" Height="150" Background="#171717" x:Class="AANotes.Windows.AddDateBaseWindows" Title="Добавить ссылку">

    <StackPanel Margin="20" Spacing="10">
		<TextBlock Text="Выберете создание базы данных:"/>
		<ComboBox Width="360" x:Name="BDType" SelectedIndex="0" SelectionChanged="UpdateParametrs">
			<ComboBoxItem Tag="1" Content="Авто"/>
			<ComboBoxItem Tag="2" Content="Существуещий"/>
			<ComboBoxItem Tag="3" Content="Файл"/>
		</ComboBox>

		<WrapPanel x:Name="DBParametrs" Margin="0" Orientation="Vertical"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button Content="Ок" Click="OnOk" Background="#252525"/>
        </StackPanel>
    </StackPanel>
</Window>