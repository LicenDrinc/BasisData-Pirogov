<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d" d:DesignWidth="0" d:DesignHeight="0"
        Width="400" Height="150" Background="#171717"
        x:Class="AANotes.Windows.AddLinkHttpWindows"
        Title="Добавить ссылку">

    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="Введите ссылку:"/>
        <TextBox x:Name="LinkBox" Watermark="https://example.com"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button Content="Ок" Click="OnOk"/>
            <Button Content="Отмена" Click="OnCancel"/>
        </StackPanel>
    </StackPanel>
</Window>